{
  "app": {
    "name": "bringa.io",
    "shortName": "bringa",
    "description": "Open source sharing and borrowing portal for communities.",
    "defaultLocale": "en",
    "locales": [
      "en",
      "de"
    ],
    "titleTemplate": "%s | bringa.io",
    "canonicalUrl": "https://app.bringa.io",
    "homeHref": "/dashboard"
  },
  "branding": {
    "logoText": "bringa.io",
    "logoPath": "/icon.svg",
    "iconPath": "/icon.svg",
    "appleTouchIconPath": "/icon.svg",
    "themeColor": "#ffffff",
    "backgroundColor": "#ffffff",
    "bornAndHostedBy": "Born and hosted by bringa.io"
  },
  "operator": {
    "organizationName": "bringa.io",
    "defaultOwnerLabel": "bringa.io",
    "contactEmail": "",
    "privacyEmail": "",
    "jurisdiction": ""
  },
  "repository": {
    "provider": "github",
    "owner": "bringaio",
    "name": "app.bringa.io",
    "url": "https://github.com/bringaio/app.bringa.io",
    "issuesUrl": "https://github.com/bringaio/app.bringa.io/issues",
    "discussionsUrl": "",
    "templateMode": "upstream"
  },
  "content": {
    "sourcePath": "content/default",
    "deploymentPath": "content/deployments",
    "publicPath": "/content/generated",
    "issuePromptPath": "/content/generated/issues/en.md",
    "requiredFiles": [
      "legal/en.md",
      "onboarding/en.md",
      "help/en.md",
      "issues/en.md"
    ]
  },
  "legal": {
    "termsPath": "/terms",
    "termsContentPath": "/content/generated/legal/en.md",
    "contentContributionLabel": "Public-domain dedication where legally possible, fallback operator license.",
    "itemGiftLabel": "Private gift to the portal operator.",
    "publicDomainIntent": true
  },
  "supabase": {
    "url": "",
    "publishableKey": "",
    "authRedirectPath": "/dashboard"
  },
  "invites": {
    "allowSignupWithoutInvite": false,
    "collectDisplayNameBeforeInvite": true
  },
  "media": {
    "acceptedImageMimeTypes": [
      "image/jpeg",
      "image/png",
      "image/webp"
    ],
    "maxUploadBytes": 10485760,
    "compressionMaxSizeMb": 1,
    "compressionMaxWidthOrHeight": 1920
  },
  "features": {
    "githubLinkInTopbar": true,
    "showBorrowedFirstOnlyWhenActive": true,
    "telegramAdminNotifications": true,
    "itemVersioning": false,
    "profilePages": false
  }
}
