# Server-only Supabase access for backups, local maintenance, and future admin tooling.
# Never expose this key in public config, client bundles, logs, screenshots, or chats.
SUPABASE_URL=
# Preferred on hosted Supabase when supported. Legacy service_role remains accepted as fallback.
SUPABASE_SECRET_KEY=
# Supabase Edge Functions may also use a JSON secret map such as {"default":"sb_secret_..."}.
SUPABASE_SECRET_KEYS=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# Backup defaults mirror scripts/backup-supabase.mjs and are checked by pnpm check:env-example.
SUPABASE_BACKUP_TABLES=profiles,items,item_versions,item_images,borrow_history,admins,item_sharing,account_deletion_requests,item_suggestions,item_flags,backup_runs,notification_events,notification_mutes
SUPABASE_BACKUP_STORAGE_BUCKETS=items
SUPABASE_BACKUP_DIR=backups/supabase
SUPABASE_BACKUP_PAGE_SIZE=1000
SUPABASE_BACKUP_STORAGE_PAGE_SIZE=1000
SUPABASE_BACKUP_AUTH_PAGE_SIZE=1000
SUPABASE_BACKUP_AUTH_USERS=0
SUPABASE_BACKUP_RECORD_RUN=1

# Public canonical URL used by Supabase Edge Functions and generated links.
APP_URL=http://localhost:3000

# Telegram admin notifications.
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram user notifications, if enabled for this deployment.
TELEGRAM_BOT_TOKEN_USER=
TELEGRAM_CHAT_ID_USER=
