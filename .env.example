# Browser-visible Supabase client values.
# Keep these aligned with resolved deployment config until the app is fully config-driven.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase access for backups, local maintenance, and future admin tooling.
# Never expose this key in public config, client bundles, logs, screenshots, or chats.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_BACKUP_TABLES=profiles,items,item_versions,item_images,borrow_history,admins,item_sharing,account_deletion_requests,item_suggestions,item_flags
SUPABASE_BACKUP_DIR=backups/supabase

# Public canonical URL used by Supabase Edge Functions and generated links.
APP_URL=http://localhost:3000

# Telegram admin notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram user notifications, if enabled for this deployment.
TELEGRAM_BOT_TOKEN_USER=
TELEGRAM_CHAT_ID_USER=
